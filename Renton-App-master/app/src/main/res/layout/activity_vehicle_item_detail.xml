<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/baseBackgroundColor"
    android:orientation="vertical"
    tools:context=".presentation.feature.partner.rentvehicle.itemdetail.PartnerRentVehicleItemDetailActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/carouselView"
                android:layout_width="match_parent"
                android:layout_height="200dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="Unknown"
                    android:textSize="17dp"
                    android:textColor="@color/black"
                    android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="5dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp.257.000,-"
                        android:textColor="@color/red"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/per_day"
                        android:textColor="@color/red"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnPackage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:letterSpacing="0"
                        android:text="@string/car_only"
                        android:textSize="12sp"
                        app:strokeColor="@color/colorAccent" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:background="@color/grey"
                        android:orientation="vertical"></LinearLayout>

                </LinearLayout>

                <androidx.gridlayout.widget.GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    app:columnCount="6"
                    app:rowCount="2">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconVehicleType"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtVehicleType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconBrand"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtBrand"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconTransmition"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtTransmition"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtMaxPassenger"
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:gravity="center"
                                android:lineSpacingExtra="0sp"
                                android:textAlignment="center"
                                android:textAllCaps="true"
                                android:textColor="@color/colorAccent"
                                android:textSize="15dp"
                                android:textStyle="bold"
                                tools:text="4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:text="@string/max_passenger"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtMaxBaggage"
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:gravity="center"
                                android:lineSpacingExtra="0sp"
                                android:textAlignment="center"
                                android:textAllCaps="true"
                                android:textColor="@color/colorAccent"
                                android:textSize="15dp"
                                android:textStyle="bold"
                                tools:text="4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:text="@string/max_baggage"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtYear"
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:gravity="center"
                                android:lineSpacingExtra="0sp"
                                android:textAlignment="center"
                                android:textAllCaps="true"
                                android:textColor="@color/colorAccent"
                                android:textSize="15dp"
                                android:textStyle="bold"
                                tools:text="2012" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:text="@string/year"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8sp" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/colorBox"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                app:civ_border_color="#000000"
                                app:civ_border_width="1dp"
                                app:civ_circle_background_color="@color/red" />

                            <TextView
                                android:id="@+id/txtColor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:text="@string/color"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8dp" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconVehicleModel"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtVehicleModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8dp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconDrivenType"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtDrivenType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8dp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/iconFuel"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                tools:srcCompat="@drawable/ic_car" />

                            <TextView
                                android:id="@+id/txtFuel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8dp"
                                tools:text="Mobil" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        app:cardPreventCornerOverlap="true"
                        app:layout_columnWeight="1"
                        app:layout_rowWeight="1"
                        app:strokeColor="@color/colorAccent"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:tint="@color/colorAccent"
                                app:srcCompat="@drawable/ic_driver" />

                            <TextView
                                android:id="@+id/txtWithDriver"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:minLines="2"
                                android:textAlignment="center"
                                android:textColor="@color/colorAccent"
                                android:textSize="8dp"
                                tools:text="Ya" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </androidx.gridlayout.widget.GridLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grey"
                android:orientation="vertical"></LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:orientation="horizontal">



                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imageProfile"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/user_image"
                        app:civ_border_color="#FFFFFF"
                        app:civ_border_width="2dp" />

                    <LinearLayout
                        android:layout_toLeftOf="@+id/btnChat"
                        android:layout_toRightOf="@+id/imageProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtPartnerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Example Rent"
                            android:lines="1"
                            android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:lines="1"
                            android:id="@+id/txtPartnerRegency"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Bandung" />

                    </LinearLayout>
                    <Button
                        android:id="@+id/btnChat"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:text="@string/chat"
                        app:icon="@drawable/ic_chat_bubble_outline"
                        app:iconGravity="textStart"
                        android:textSize="14dp"
                        android:gravity="center"
                        app:iconPadding="5dp"
                        android:layout_alignParentRight="true"
                        app:iconTint="@color/calendar_selected_day_bg"
                        app:strokeColor="@color/colorAccent" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:text="@string/vehicle_detail_info"
                        android:textSize="12sp" />

                    <RelativeLayout
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp">

                        <fragment
                            android:id="@+id/map"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="150dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/centerMarker"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="48dp"
                                app:srcCompat="@drawable/marker" />
                        </LinearLayout>
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/txtPartnerAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        tools:text="Jl. Caringin Gang Lumbung 2 No 43 RT 3 RW 3 Bandung" />


                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grey"
                android:orientation="vertical"></LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtReviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:text="@string/reviews"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Review (105)" />

                <LinearLayout
                    android:id="@+id/reviewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <Button
                        android:id="@+id/btnReview"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:text="@string/show_more"
                        android:textColor="@color/colorAccent"
                        app:icon="@drawable/ic_format_list_bulleted"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp"
                        app:iconTint="@color/colorAccent"
                        app:strokeColor="@color/colorAccent" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtReviewMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="50dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="50dp"
                    android:text="@string/no_review"
                    android:textAlignment="center"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/grey"
                android:orientation="vertical"></LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView30"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:text="@string/date_reserved"
                    android:textAlignment="center"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.savvi.rangedatepicker.CalendarPickerView
                    android:id="@+id/calendar_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="10dp"
                    android:clipToPadding="false"
                    android:scrollbarStyle="outsideOverlay"
                    app:tsquare_dividerColor="@color/white"
                    app:tsquare_headerTextColor="@color/colorAccent"
                    app:tsquare_orientation_horizontal="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/checkoutInfoContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="2"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView17"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="10dp"
                        android:text="@string/total_payment"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rp. 771.000,-"
                        android:textColor="@color/red"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtOrderDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2 Days"
                    android:textSize="12sp"
                    android:textStyle="italic" />

            </LinearLayout>

            <Button
                android:id="@+id/btnOrder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/order"
                android:textAllCaps="true" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
# Template konfigurasi sensitif -- copy jadi `.env.development`, `.env.testing`,
# atau `.env.production` (sesuai environment yang aktif di server ini) lalu isi
# nilai aslinya. File `.env.*` (selain file `.example` ini) sengaja di-gitignore,
# tidak pernah masuk repo -- lihat index.php + env_loader.php untuk cara baca.

DB_HOSTNAME=localhost
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

MAIL_EMAIL=
MAIL_PASSWORD=
MAIL_SMTP_HOST=ssl://mail.renton.co.id
MAIL_SMTP_PORT=465

# FCM HTTP v1 -- opsional, isi hanya kalau service account TIDAK ditaruh di
# lokasi default (RentonBachkEnd-main/.fcm-service-account.json). Ambil file
# ini dari Firebase Console > Project Settings > Service accounts >
# Generate new private key.
FCM_SERVICE_ACCOUNT_PATH=

# Shared secret yang wajib dikirim app Android lewat header X-App-Secret
# (lihat Api_Base_Controller). Harus SAMA PERSIS dengan SECRET_KEY di
# Renton-App-master/configdev.env atau configprod.env.
APP_SECRET_KEY=

# Random string panjang, generate baru per environment, mis:
# php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
ENCRYPTION_KEY=

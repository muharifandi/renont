# Folder ini hanya untuk menyimpan file upload (gambar/dokumen), bukan kode.
# Blokir eksekusi PHP sebagai lapisan pertahanan kedua terhadap upload
# berbahaya (lihat RentOn-Audit-Keamanan-REST-API.md).
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.(php|php3|php4|php5|php7|phtml|pht)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

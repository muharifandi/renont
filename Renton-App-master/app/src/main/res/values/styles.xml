<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>

        <item name="android:fontFamily">sans-serif</item> <!-- Roboto is default sans-serif on Android -->
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="actionMenuTextColor">@color/black</item>
        <item name="colorControlNormal">@color/black</item>
    </style>

    <style name="AppTheme.WithActionbar" parent="Theme.MaterialComponents.Light">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="actionBarTheme">@style/AppTheme.ActionBar</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="AppTheme.ActionBar" parent="Theme.MaterialComponents.Light">
        <item name="colorPrimary">@color/white</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorPrimary">@color/actionBarColor</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <!-- ================================================== -->
    <!-- TYPOGRAPHY SYSTEM (ROBOTO BASED)                   -->
    <!-- ================================================== -->

    <style name="AppText" parent="android:Widget.TextView">
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Base Scale Templates -->
    <style name="AppText.Regular"><item name="android:textStyle">normal</item></style>
    <style name="AppText.Medium"><item name="android:fontFamily">sans-serif-medium</item></style>
    <style name="AppText.Bold"><item name="android:textStyle">bold</item></style>
    <style name="AppText.Italic"><item name="android:textStyle">italic</item></style>
    <style name="AppText.BoldItalic"><item name="android:textStyle">bold|italic</item></style>

    <!-- Specific Scales -->
    <!-- 2sp -->
    <style name="AppText.R2" parent="AppText.Regular"><item name="android:textSize">@dimen/sp_2</item></style>
    <style name="AppText.M2" parent="AppText.Medium"><item name="android:textSize">@dimen/sp_2</item></style>
    <style name="AppText.B2" parent="AppText.Bold"><item name="android:textSize">@dimen/sp_2</item></style>
    <style name="AppText.I2" parent="AppText.Italic"><item name="android:textSize">@dimen/sp_2</item></style>

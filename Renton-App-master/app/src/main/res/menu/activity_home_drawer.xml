<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:showIn="navigation_view">
    <item
        android:id="@+id/nav_home"
        android:icon="@drawable/ic_home"
        android:title="@string/menu_home" />
    <item
        android:id="@+id/nav_news"
        android:icon="@drawable/ic_format_list_bulleted"
        android:title="@string/menu_news" />
    <group

        android:id="@+id/menu_main"
        android:checkableBehavior="single">


        <item
            android:id="@+id/menu_customer"
            android:title="@string/customer">
            <menu>
                <item
                    android:id="@+id/nav_account"
                    android:icon="@drawable/ic_person_black"
                    android:title="@string/menu_account" />
                <item
                    android:id="@+id/nav_transaction"
                    android:icon="@drawable/ic_chrome_reader_mode"
                    android:title="@string/menu_transaction" />
                <item
                    android:id="@+id/nav_customer_chat"
                    android:icon="@drawable/ic_chat"
                    app:actionViewClass="android.widget.TextView"
                    android:title="@string/chat" />
            </menu>
        </item>
        <item
            android:id="@+id/menu_partner"
            android:title="@string/partner">
            <menu>
                <item
                    android:id="@+id/nav_partner_register"
                    android:icon="@drawable/ic_person_black"
                    android:title="@string/menu_become_partner" />
                <group
                    android:id="@+id/menu_main_partner"
                    android:checkableBehavior="single">
                    <item
                        android:id="@+id/nav_partner_profile"
                        android:icon="@drawable/ic_person_black"
                        android:title="@string/menu_partner_profile"
                        app:showAsAction="never" />
                    <item
                        android:id="@+id/nav_partner_chat"
                        android:icon="@drawable/ic_chat"
                        app:actionViewClass="android.widget.TextView"
                        android:title="@string/chat" />
                    <item
                        android:id="@+id/nav_partner_reward"
                        android:icon="@drawable/ic_card_giftcard"
